#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)

remote_name="${1:-}"

while read local_ref local_oid remote_ref remote_oid
do
    case "$local_oid" in
        0000000000000000000000000000000000000000)
            continue
            ;;
    esac

    case "$remote_oid" in
        0000000000000000000000000000000000000000)
            default_remote_ref=""
            if [ -n "$remote_name" ]; then
                default_remote_ref=$(git symbolic-ref --quiet --short "refs/remotes/$remote_name/HEAD" 2>/dev/null || true)
            fi
            if [ -n "$default_remote_ref" ]; then
                commit_range="$default_remote_ref..$local_oid"
                exclude_remotes=""
            else
                commit_range="$local_oid"
                exclude_remotes="--exclude-remotes"
            fi
            ;;
        *)
            commit_range="$remote_oid..$local_oid"
            exclude_remotes=""
            ;;
    esac

    python3 "$repo_root/.github/commit_checks/check_conventional_commits.py" --range "$commit_range" --allow-empty-range $exclude_remotes
done
