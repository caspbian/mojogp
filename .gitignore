# Repository-root hygiene
# The root directory is curated source/package surface only. Generated outputs,
# scratch data, logs, figures, papers, local package-manager files, and one-off
# reports must not be created or kept at the top level.
/*.log
/*.png
/*.jpg
/*.jpeg
/*.pdf
/*.json
/*.txt
/*.npy
/*.npz
/*.pkl
/*.prof
/*.db
/*.sqlite
/uv.lock
/package.json
/package-lock.json
/requirements.txt
/*_output.*
/*_results.*
/*_results_*.*
/*_summary.*
/*_validation.*
/accuracy_test_results.*
/benchmark_*_results.*
/benchmark_output.*
/debug_*.*
/test_*.npy
/test_*.npz
/test_*

